rules_version = '2';

/**
 * Firestore Security Rules for Handyman Platform
 *
 * Collections:
 * - users: User profiles (customers and handymen)
 * - jobs: Job requests and details
 * - handymen: Handyman-specific data (profiles, ratings, certifications)
 * - jobApplications: Applications from handymen for jobs
 * - reviews: Customer reviews for completed jobs
 * - notifications: User notifications
 * - payments: Payment records
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isHandyman() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/handymen/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/handymen/$(request.auth.uid)).data.verified == true;
    }

    // Admin is identified by the Firebase Auth custom claim `admin: true`.
    // This is set by scripts/grant-admin.js (bootstrap) or by the
    // setAdminClaim Cloud Function. Custom claims travel inside the ID
    // token, so this check is a constant-time field lookup — no Firestore
    // read, no extra latency, no per-request quota cost. Keep the rule
    // definition in sync with the equivalent helpers in functions/index.js
    // and storage.rules.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Fields on a job document that represent settled financial state.
    // Clients (customer or handyman) must NEVER mutate these directly —
    // they are written exclusively by Cloud Functions (Admin SDK) in
    // response to Stripe events (payment capture, transfer, refund) or
    // admin actions. Mutating any of them client-side would let a user
    // forge payment status, hijack a transfer, or fake a refund.
    //
    // Notes on what's intentionally NOT here:
    //   - paymentResult / paymentIntentId / paymentCompletedAt are written
    //     by the customer's client during the create→confirm flow. Cross-
    //     referencing the paymentIntent metadata back to the job is the
    //     defense for those (Batch B follow-up).
    //   - status / handymanId are workflow fields the customer/handyman
    //     legitimately update; financial state-machine integrity for
    //     status (e.g. blocking client-set 'released') is enforced
    //     server-side by the release/refund Cloud Functions.
    function jobSystemFields() {
      return [
        'paymentStatus',
        'paymentSucceededAt',
        'paymentReleasedAt',
        'paymentReleasedBy',
        'paymentRefundedAt',
        'paymentReleaseError',
        'paymentReleaseFailedAt',
        'paymentBreakdown',
        'escrowReleased',
        'priceAdjustment',
        'transferId',
        'transferReversalId',
        'chargeId',
        'refundId',
        'refundedAmount'
      ];
    }

    function touchesJobSystemFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(jobSystemFields());
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isSignedIn() && isOwner(userId);

      // Users can create their own profile
      allow create: if isSignedIn() && isOwner(userId);

      // Users can update their own profile (except role)
      allow update: if isSignedIn() && isOwner(userId) &&
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Jobs collection
    match /jobs/{jobId} {
      // Any signed-in user can read jobs. Handymen browse the board for
      // available work, and customers see their own job state.
      //
      // Known caveat (Batch B): customerPhone composite indexes are still
      // present because the whatsappWebhook needs them to find the
      // pending job by an incoming phone number. That means an
      // authenticated user with read access can enumerate jobs by
      // phone. Mitigation lives in restricting WHO can read; tightening
      // this to (owner || assignedHandyman || isAdmin) would break the
      // public job board, so the deeper fix is to route the webhook's
      // lookup through a server-only mirror collection rather than the
      // live jobs collection.
      allow read: if isSignedIn();

      // Customers can create jobs (including anonymous users)
      allow create: if isSignedIn() &&
                      request.resource.data.customerId == request.auth.uid;

      // Job owner or assigned handyman can update workflow fields. Financial
      // and system fields (see jobSystemFields()) are NEVER writable by
      // clients — those flow only through Cloud Functions / Admin SDK, which
      // bypasses these rules. Admins can update anything (e.g. dispute
      // resolution writes status changes).
      //
      // The "claim an unassigned job" branch (last one) requires
      // isHandyman() — without it, any signed-in user (including a
      // customer on an anonymous session) could set handymanId to their
      // own UID and lock a job to themselves. This became a live risk
      // once job deep-links started going out over WhatsApp, where
      // messages get forwarded to non-handymen. isHandyman() also
      // enforces verified == true, so rejected handymen cannot claim.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          !touchesJobSystemFields() &&
          (
            isOwner(resource.data.customerId) ||
            (resource.data.handymanId != null && isOwner(resource.data.handymanId)) ||
            (resource.data.handymanId == null && isHandyman() && request.resource.data.handymanId == request.auth.uid)
          )
        )
      );

      // Only job owner can delete (within limits)
      allow delete: if isSignedIn() &&
                      isOwner(resource.data.customerId) &&
                      resource.data.status == 'pending';
    }

    // Handymen collection
    match /handymen/{handymanId} {
      // Anyone signed in can read handyman profiles (browse / display).
      allow read: if isSignedIn();

      // Handyman can create their own profile
      allow create: if isSignedIn() && isOwner(handymanId);

      // Handyman can update their own profile, but NOT:
      //   - verified / status: gate verified-handyman privileges (admin-only).
      //   - stripe* capability fields: gate Stripe-payout eligibility and are
      //     written ONLY by the server (syncStripeOnboardingStatus + the
      //     account.updated webhook, both Admin SDK, which bypasses rules).
      //     Locking them here is what makes onboarding-completion tamper-proof:
      //     a handyman cannot self-set stripeOnboardingCompleted=true to skip
      //     onboarding. stripeConnectedAccountId stays writable — it's just the
      //     account reference, set when the Connect account is created, not a
      //     privilege gate.
      allow update: if isSignedIn() && isOwner(handymanId) &&
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
                        'verified', 'status',
                        'stripeConnectedAccountId',
                        'stripeOnboardingCompleted', 'stripeAccountStatus',
                        'stripeDetailsSubmitted', 'stripeChargesEnabled', 'stripePayoutsEnabled'
                      ]));

      // Admins can update anything, including verified/status. The email
      // approval flow used to allow ANY caller to flip a pending handyman
      // to active — that was a self-approval vulnerability. Operators must
      // now be signed in as an admin before clicking approval links;
      // ApproveHandyman.jsx renders a login prompt when they aren't.
      allow update: if isAdmin();

      // Only admins can delete
      allow delete: if isAdmin();
    }

    // Job Applications collection
    match /jobApplications/{applicationId} {
      // Job owner and applicant can read
      allow read: if isSignedIn() && (
        isOwner(resource.data.handymanId) ||
        isOwner(resource.data.customerId)
      );

      // Verified handymen can create applications
      allow create: if isSignedIn() &&
                      isHandyman() &&
                      request.resource.data.handymanId == request.auth.uid;

      // Handyman can update their own application
      allow update: if isSignedIn() && isOwner(resource.data.handymanId);

      // Handyman can delete their own application
      allow delete: if isSignedIn() && isOwner(resource.data.handymanId);
    }

    // Reviews collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if isSignedIn();

      // Customer who completed job can create review
      allow create: if isSignedIn() &&
                      request.resource.data.customerId == request.auth.uid &&
                      exists(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)) &&
                      get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.status == 'completed';

      // Customer can update their own review
      allow update: if isSignedIn() && isOwner(resource.data.customerId);

      // Customer can delete their own review
      allow delete: if isSignedIn() && isOwner(resource.data.customerId);
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isSignedIn() && isOwner(resource.data.userId);

      // Notifications are created server-side only.
      // Cloud Functions use the Admin SDK, which bypasses these rules,
      // so denying client creation prevents spoofing/spam without breaking server writes.
      allow create: if false;

      // Users can update their own notifications (mark as read)
      allow update: if isSignedIn() && isOwner(resource.data.userId);

      // Users can delete their own notifications
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Payments collection - restricted access
    match /payments/{paymentId} {
      // Owner (customer or handyman on the record) or admin can read.
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.handymanId == request.auth.uid ||
        isAdmin()
      );

      // The creator must be the customer on the payment record. Previously
      // any signed-in user could create arbitrary payment docs claiming
      // any customerId/handymanId/amount, which enabled spoofed payment
      // records that downstream code might trust.
      allow create: if isSignedIn() &&
                      request.resource.data.customerId == request.auth.uid;

      // Only system/admin can update payments
      allow update: if isAdmin();

      // No one can delete payments
      allow delete: if false;
    }

    // Customers collection (legacy support)
    match /customers/{customerId} {
      allow read, write: if isSignedIn() && isOwner(customerId);
    }

    // Stripe webhook event log — used for webhook deduplication.
    // Written only by Cloud Functions (Admin SDK bypasses these rules).
    // Clients have no business reading or writing this collection.
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    // Audit log — append-only record of money-movement and admin
    // actions (fund release, refund, transfer reversal, admin
    // grant/revoke, handyman approval). Cloud Functions write here
    // via the Admin SDK (which bypasses rules); admins can read for
    // investigation. No client writes, no deletes — even admins.
    // Deletions would defeat the audit purpose; if data must be
    // purged for compliance, do it via the GCP console with a
    // documented retention policy.
    match /auditLog/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}