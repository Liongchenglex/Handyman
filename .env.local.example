# ========================================
# EazyDone Environment Configuration
# ========================================
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local to git

# ========================================
# EmailJS Configuration
# ========================================
# Sign up at: https://www.emailjs.com/ (free tier: 200 emails/month)
# 1. Create an account
# 2. Add an email service (Gmail, Outlook, etc.)
# 3. Create email templates for handyman and operations notifications
# 4. Get your service ID, template IDs, and public key from dashboard

REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here
REACT_APP_EMAILJS_TEMPLATE_HANDYMAN=your_handyman_template_id_here
REACT_APP_EMAILJS_TEMPLATE_OPERATIONS=your_operations_template_id_here
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here

# ========================================
# Operations & Approval Configuration
# ========================================

# Operations team email (receives handyman registration notifications)
# This can be your personal email or a team email address
REACT_APP_OPERATIONS_EMAIL=your-email@example.com

# NOTE: approval token signing has moved server-side. The frontend no
# longer needs APPROVAL_SECRET — the generateApprovalToken Cloud
# Function (functions/index.js) mints HS256 JWTs from the
# functions/.env APPROVAL_SECRET variable, and processHandymanApproval
# verifies them. Set the server-side variable in functions/.env.
#   functions/.env:    APPROVAL_SECRET=<32+ char random string>

# Approval base URL (where approval links redirect)
# LOCAL TESTING: http://localhost:3000/admin/approve-handyman
# PRODUCTION: https://eazydone-d06cf.web.app/admin/approve-handyman
#
# IMPORTANT: Use localhost URL for local testing, production URL for deployed app
REACT_APP_APPROVAL_BASE_URL=http://localhost:3000/admin/approve-handyman

# ========================================
# Firebase Configuration
# ========================================
# Get these from Firebase Console > Project Settings > General

REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id

# Cloud Functions region. Optional — defaults to us-central1.
# All project-bound URLs (Cloud Functions endpoints, hosting domain,
# Firebase Console links) are derived from REACT_APP_FIREBASE_PROJECT_ID
# + this region in src/config/firebaseProject.js. To point the app at a
# different Firebase project (e.g. switching from a dev project to the
# production project), change REACT_APP_FIREBASE_PROJECT_ID here — no
# code edits required.
REACT_APP_FUNCTIONS_REGION=us-central1

# ========================================
# Twilio WhatsApp / Meta Cloud API / GreenAPI
# ========================================
# IMPORTANT: server credentials must NEVER be prefixed REACT_APP_*.
# Anything starting with REACT_APP_ is baked into the production JS
# bundle by Create React App and is therefore visible to any browser
# user. That means Twilio Auth Tokens, WhatsApp Cloud API access tokens,
# GreenAPI tokens, and the approval secret (see Batch B migration to
# server-issued JWTs) all belong in functions/.env, NOT here.
#
# The frontend dispatches notifications via the sendWhatsAppNotification
# Cloud Function proxy and never holds the underlying credentials.
#
# Variables that live in functions/.env (server-only):
#   TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_WHATSAPP_FROM
#   TWILIO_TEMPLATE_JOB_CREATED, TWILIO_TEMPLATE_JOB_ACCEPTED,
#   TWILIO_TEMPLATE_JOB_COMPLETION
#   WHATSAPP_ACCESS_TOKEN, WHATSAPP_PHONE_NUMBER_ID, WHATSAPP_API_VERSION
#   GREENAPI_API_URL, GREENAPI_ID_INSTANCE, GREENAPI_API_TOKEN
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET

# ========================================
# EmailJS Template Setup Guide
# ========================================
#
# HANDYMAN ACKNOWLEDGMENT EMAIL TEMPLATE
# Template ID: {{to be configured in EmailJS dashboard}}
# Template Variables:
#   - {{to_email}} - Handyman's email address
#   - {{to_name}} - Handyman's name
#   - {{subject}} - Email subject
#   - {{message_html}} - HTML content of the email
#   - {{company_name}} - Company name (EazyDone)
#
# OPERATIONS NOTIFICATION EMAIL TEMPLATE
# Template ID: {{to be configured in EmailJS dashboard}}
# Template Variables:
#   - {{to_email}} - Operations team email
#   - {{subject}} - Email subject
#   - {{message_html}} - HTML content with all handyman details
#   - {{handyman_name}} - Handyman's name
#   - {{handyman_email}} - Handyman's email
#   - {{handyman_id}} - Handyman's UID
#   - {{approval_token}} - Token for approval link
#
# ========================================
