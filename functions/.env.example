# ===========================================
# Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# For different environments, use:
#   - .env.local      → Local development
#   - .env.uat        → UAT/Staging
#   - .env.production → Production
# Then copy the appropriate file to .env before deploying

# App URL - Base URL for your application
# This is used to construct redirect URLs for Stripe Connect, etc.
APP_URL=http://localhost:3000

# ===========================================
# Stripe Configuration
# ===========================================
# Get these values from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# Green-API Configuration
# ===========================================
# Get these values from https://console.green-api.com
GREENAPI_API_URL=https://api.green-api.com
GREENAPI_ID_INSTANCE=your_id_instance_here
GREENAPI_API_TOKEN=your_api_token_here

# ===========================================
# Email Notification Configuration
# ===========================================
# For Gmail: Use smtp.gmail.com with an App Password
# Create App Password: Google Account > Security > 2-Step Verification > App passwords
ADMIN_EMAIL=your_admin_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password_here
